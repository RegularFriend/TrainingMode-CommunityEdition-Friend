CompileFlags:
  # Compiler used for system header discovery (stdarg.h, stdint.h, stddef.h).
  # Must match the DevKitPro install path on your machine.
  Compiler: C:\devkitPro\devkitPPC\bin\powerpc-eabi-gcc.exe

  Add:
    - -DTM_DEBUG
    - -Wall
    - -Wextra
    - -Wno-char-subscripts
    - -Wno-builtin-declaration-mismatch
    - -Wno-unused-parameter
    # Target needed so clangd doesn't complain about PPC-specific GCC pragmas
    - --target=powerpc-eabi

Diagnostics:
  # Suppress false positives that come from clangd not fully understanding
  # GCC-style inline asm or PPC-specific attributes
  Suppress:
    - drv_unknown_argument